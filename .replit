run = "sh start.sh"
modules = ["python-3.11"]

[nix]
channel = "stable-23_11"
packages = ["glibcLocales"]

[deployment]
run = ["sh", "-c", "gunicorn -c gunicorn.conf.py app:app"]

[env]
PORT = "5000"
PYTHONUNBUFFERED = "1"
AUTO_START_LIVE = "1"
LIVE_POLL_INTERVAL = "60"

[packager]
language = "python3"

[packager.features]
enabled = ["python311"]

[languages.python3]
pattern = "**/*.py"

[gitHubImport]
requiredRepo = ""
commit = ""

[agent]
expertMode = true

[userenv]

[userenv.shared]
IG_ACCOUNT_TYPE = "DEMO"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
