run = "sh start.sh"

[nix]
channel = "stable-23_11"

[deployment]
run = ["sh", "-c", "gunicorn -c gunicorn.conf.py app:app"]

[env]
PORT = "5000"
PYTHONUNBUFFERED = "1"
AUTO_START_LIVE = "1"
LIVE_POLL_INTERVAL = "60"

[packager]
language = "python3"

[packager.features]
enabled = ["python311"]

[languages.python3]
pattern = "**/*.py"

[gitHubImport]
requiredRepo = ""
commit = ""

[agent]
expertMode = true
